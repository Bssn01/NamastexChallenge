# Runtime local
NAMASTEX_CONVERSATION_ID=local-demo
NAMASTEX_STORE_DRIVER=json
NAMASTEX_STORE_PATH=data/genie-research-store.json
NAMASTEX_OUTBOX_PATH=data/genie-outbox.jsonl

# Runtime Docker/Postgres
POSTGRES_PASSWORD=namastex
POSTGRES_PORT=5432
NAMASTEX_DATABASE_URL=postgresql://namastex:namastex@localhost:5432/namastex

# Omni/WhatsApp
OMNI_API_KEY=
OMNI_DEFAULT_INSTANCE_NAME=namastex-wa
OMNI_ACCESS_MODE=allowlist
OMNI_ALLOW_PHONES=+5511999999999
OMNI_PORT=8882
NATS_PORT=4222
NATS_MONITOR_PORT=8222

# Admin panel
# Run manually with `npm run admin`; it binds to 127.0.0.1 by default.
# NAMASTEX_ADMIN_PORT=0

# Credencial obrigatória para análise de GitHub
GITHUB_TOKEN=ghp_...

# Ordem de provedores LLM
NAMASTEX_LLM_PRIMARY=claude-cli
NAMASTEX_LLM_FALLBACKS=codex-cli,openrouter:moonshotai/kimi-k2
NAMASTEX_CLAUDE_CODE_MODEL=claude-sonnet-4-6

# Autenticação Claude.
# Local: rode `claude` no terminal e faça login; deixe estas duas vazias.
# Docker/headless: prefira ANTHROPIC_API_KEY, porque o container não acessa o Keychain do macOS.
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=

# Provedores API opcionais
OPENROUTER_API_KEY=sk-or-...
# XAI_API_KEY=xai-...
# MOONSHOT_API_KEY=sk-...

# Sugestão padrão opcional para fluxos legados /repo sem alvo explícito
# GITHUB_OWNER=openai
# GITHUB_REPO=codex

# Hacker News
# HACKERNEWS_API_BASE=https://hn.algolia.com/api/v1
# HACKERNEWS_USER_AGENT=NamastexChallenge/0.1.0

# X/Grok
# X_SEARCH_MODEL=grok-4.20-reasoning
# X_SEARCH_LIMIT=5

# Cache de análise de repositórios
# NAMASTEX_REPO_CACHE_DIR=data/repos

# Field Theory opcional
# FIELDTHEORY_BIN=ft
# FT_DATA_DIR=data/fieldtheory

# Genie Brain opcional
# GENIE_BRAIN_BIN=genie
# GENIE_BRAIN_INGEST_DIR=data/brain-ingest
# GENIE_BRAIN_SEARCH_LIMIT=5
