NAMASTEX_MODE=mock
NAMASTEX_TURN_EXECUTOR=auto
NAMASTEX_SESSION_ID=local-demo
NAMASTEX_STORE_PATH=data/genie-research-store.json
NAMASTEX_OUTBOX_PATH=data/genie-outbox.jsonl

# Real/live bridge mode tries Claude first, then Codex/OpenAI, then the local workflow.
# Set NAMASTEX_TURN_EXECUTOR=codex to force the ChatGPT/Codex CLI path.

# Claude Code login is optional when using the Claude path.
# ANTHROPIC_API_KEY=

# Grok synthesis
# OPENROUTER_API_KEY=
# XAI_API_KEY=
# GROK_MODEL=x-ai/grok-4.1-fast
# X_SEARCH_MODEL=grok-4.20-reasoning
# X_SEARCH_LIMIT=5

# Hacker News search (optional overrides)
# HACKERNEWS_API_BASE=https://hn.algolia.com/api/v1
# HACKERNEWS_USER_AGENT=NamastexChallenge/0.1.0

# GitHub validation
# GITHUB_TOKEN=
# GITHUB_OWNER=Bssn01
# GITHUB_REPO=NamastexChallenge

# Repo analysis cache
# NAMASTEX_REPO_CACHE_DIR=data/repos

# Optional Field Theory integration
# FIELDTHEORY_BIN=ft
# FT_DATA_DIR=data/fieldtheory

# Optional Genie Brain integration (requires `genie brain install` + `genie brain init`)
# GENIE_BRAIN_BIN=genie
# GENIE_BRAIN_INGEST_DIR=data/brain-ingest
# GENIE_BRAIN_SEARCH_LIMIT=5

# Kimi / Moonshot integration
# MOONSHOT_API_KEY=sk-...
# KIMI_API_BASE=https://api.moonshot.ai/v1
# KIMI_MODEL=kimi-k2.6
# KIMI_CLI_BIN=kimi
# NAMASTEX_KIMI_MODE=api
