NAMASTEX_SESSION_ID=local-demo
NAMASTEX_STORE_PATH=data/genie-research-store.json
NAMASTEX_OUTBOX_PATH=data/genie-outbox.jsonl

# Required credential
GITHUB_TOKEN=ghp_...

# Provider order
NAMASTEX_LLM_PRIMARY=claude-cli
NAMASTEX_LLM_FALLBACKS=codex-cli,openrouter:moonshotai/kimi-k2

# Optional provider credentials
# ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...
# XAI_API_KEY=xai-...
# MOONSHOT_API_KEY=sk-...

# Optional GitHub default suggestion used only when the user omits a repo in a legacy /repo call
# GITHUB_OWNER=openai
# GITHUB_REPO=codex

# Hacker News search (optional overrides)
# HACKERNEWS_API_BASE=https://hn.algolia.com/api/v1
# HACKERNEWS_USER_AGENT=NamastexChallenge/0.1.0

# X search (optional overrides)
# X_SEARCH_MODEL=grok-4.20-reasoning
# X_SEARCH_LIMIT=5

# Repo analysis cache
# NAMASTEX_REPO_CACHE_DIR=data/repos

# Optional Field Theory integration
# FIELDTHEORY_BIN=ft
# FT_DATA_DIR=data/fieldtheory

# Optional Genie Brain integration (requires `genie brain install` + `genie brain init`)
# GENIE_BRAIN_BIN=genie
# GENIE_BRAIN_INGEST_DIR=data/brain-ingest
# GENIE_BRAIN_SEARCH_LIMIT=5
