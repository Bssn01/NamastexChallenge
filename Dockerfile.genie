FROM node:22-slim

ARG AUTOMAGIK_OMNI_VERSION=2.260410.1
ARG AUTOMAGIK_GENIE_VERSION=4.260423.10
ARG PGSERVE_VERSION=1.1.10

RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates curl git gosu jq procps tmux unzip \
  && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://bun.sh/install | bash
ENV PATH="/root/.bun/bin:/root/.local/bin:$PATH"

RUN bun add -g \
    @automagik/omni@${AUTOMAGIK_OMNI_VERSION} \
    @automagik/genie@${AUTOMAGIK_GENIE_VERSION} \
    pgserve@${PGSERVE_VERSION} \
  && test "$(genie --version)" = "${AUTOMAGIK_GENIE_VERSION}" \
  && node -e "const checks = [['@automagik/omni', '${AUTOMAGIK_OMNI_VERSION}'], ['@automagik/genie', '${AUTOMAGIK_GENIE_VERSION}'], ['pgserve', '${PGSERVE_VERSION}']]; for (const [name, version] of checks) { const pkg = require('/root/.bun/install/global/node_modules/' + name + '/package.json'); if (pkg.version !== version) throw new Error(name + ' expected ' + version + ' got ' + pkg.version); }" \
  && node /root/.bun/install/global/node_modules/@automagik/genie/scripts/postinstall-tmux.js \
  && genie sec verify-install
RUN npm install -g @anthropic-ai/claude-code @openai/codex

RUN ln -sf /root/.bun/bin/omni /usr/local/bin/omni \
  && ln -sf /root/.bun/bin/genie /usr/local/bin/genie \
  && ln -sf /root/.bun/bin/bun /usr/local/bin/bun \
  && mkdir -p /root/.local/bin \
  && chmod 755 /root \
  && chmod -R a+rX /root/.bun /root/.local

RUN useradd -m -s /bin/bash appuser

WORKDIR /workspace/app
COPY package.json package-lock.json ./
RUN npm ci

COPY tsconfig.json tsconfig.build.json biome.json ./
COPY src ./src
COPY scripts ./scripts
COPY agents ./agents
COPY agent.yaml CLAUDE.md AGENTS.md ./

COPY docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh \
  && chown -R appuser:appuser /workspace/app /home/appuser

ENTRYPOINT ["/docker-entrypoint.sh"]
